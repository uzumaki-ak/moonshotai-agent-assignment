# this file keeps local and build artifacts out of git
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
.env
.env.*
!.env.example

node_modules/
frontend/node_modules/
frontend/dist/

backend/.mypy_cache/
backend/.pytest_cache/
backend/.ruff_cache/

playwright-report/
test-results/

*.log
.DS_Store
Thumbs.db

/data/raw/*.json
/data/cleaned/*.csv
/data/runs/**
!data/raw/.gitkeep
!data/cleaned/.gitkeep
!data/runs/.gitkeep
