# this file stores local env keys and run config
APP_NAME=moonshot luggage intelligence
APP_ENV=dev
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/moonshot_ai

# this is fallback llm chain order
LLM_CHAIN=gemini,groq,euron,local

# openrouter handles gemini and euron models
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GEMINI_MODEL=google/gemini-2.5-flash
EURON_MODEL=openrouter/auto

# groq direct fallback
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# local ollama fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# scraper controls
SCRAPER_MAX_PRODUCTS_PER_BRAND=12
SCRAPER_MAX_REVIEWS_PER_PRODUCT=60
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_SECONDS=35
SCRAPER_DELAY_MS=900
